# Sprint 1 baseline local development environment variables.
# Copy values into .env.local (ignored by git) for your machine.

# Auth service
AUTH_SERVICE_URL=http://localhost:4000
NEXT_PUBLIC_AUTH_SERVICE_URL=$AUTH_SERVICE_URL

# Supabase (use anon/public key only here; never commit service-role keys)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_SUPABASE_URL=$SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=$SUPABASE_ANON_KEY

# Downstream APIs
EVENTS_API_BASE_URL=http://localhost:4100
SIGNUPS_API_BASE_URL=http://localhost:4200
NEXT_PUBLIC_EVENTS_API_BASE_URL=$EVENTS_API_BASE_URL
NEXT_PUBLIC_SIGNUPS_API_BASE_URL=$SIGNUPS_API_BASE_URL

# Session (set a strong random value outside of git-tracked files)
SESSION_SECRET=change-me-in-local-env
